// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id          String   @id @default(cuid())
  title       String
  category    String   // VMC, Chauffage, Clim, Plomberie
  image       String
  description String?
  createdAt   DateTime @default(now())
}

model Partner {
  id        String   @id @default(cuid())
  name      String
  logo      String
  type      String   // Distributeur, Marque
  order     Int      @default(0)
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  content   String
  location  String?
  rating    Int      @default(5)
  date      DateTime @default(now())
}
