// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Project {
  id          String   @id @default(cuid())
  title       String
  category    String   // VMC, Chauffage, Clim, Plomberie
  image       String
  description String?
  createdAt   DateTime @default(now())
}

model Partner {
  id        String   @id @default(cuid())
  name      String
  logo      String
  type      String   // Distributeur, Marque
  order     Int      @default(0)
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  content   String
  location  String?
  rating    Int      @default(5)
  date      DateTime @default(now())
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  status    String   @default("NEU") // NEU, EN_COURS, GAGNE, PERDU
  createdAt DateTime @default(now())
}

model Tender {
  id          String   @id @default(cuid())
  title       String
  description String?
  source      String?
  link        String?
  publishedAt DateTime @default(now())
  category    String?  // Plomberie, CVC, etc.
}

